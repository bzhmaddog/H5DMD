{
    "name": "h5dmd",
    "version": "3.0.0",
    "description": "WebGPU-based virtual DMD (dot-matrix display) rendering library for the browser.",
    "keywords": [
        "dmd",
        "dot-matrix",
        "webgpu",
        "canvas",
        "pinball",
        "display"
    ],
    "homepage": "https://github.com/bzhmaddog/h5dmd#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bzhmaddog/h5dmd.git"
    },
    "bugs": {
        "url": "https://github.com/bzhmaddog/h5dmd/issues"
    },
    "author": "bzhmaddog",
    "license": "LGPL-3.0-or-later",
    "type": "module",
    "sideEffects": false,
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@eslint/js": "^9.19.0",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.61.1",
        "@vitest/coverage-v8": "^4.1.9",
        "@webgpu/types": "^0.1.40",
        "eslint": "^9.19.0",
        "globals": "^15.14.0",
        "jsdom": "^29.1.1",
        "prettier": "^3.9.6",
        "tslib": "^2.6.2",
        "typedoc": "^0.25.13",
        "typescript": "^5.4.2",
        "vitest": "^4.1.9",
        "vitest-canvas-mock": "^1.1.4"
    },
    "scripts": {
        "watch": "tsc --watch",
        "build": "tsc",
        "build:docs": "npx typedoc --options typedoc.config.json",
        "prepublishOnly": "npm run build",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "version": "node scripts/sync-version.mjs && git add src/dmd.ts"
    }
}
